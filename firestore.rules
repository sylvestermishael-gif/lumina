rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL BY DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPERS
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // POSTS
    match /posts/{postId} {
      allow read: if true; // Public posts
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'viewsCount', 'commentsCount'])
      );
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      // COMMENTS
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // COMMUNITIES
    match /communities/{communityId} {
      allow read: if true;
      allow write: if isSignedIn(); // Simplified for now
    }

    // NOTIFICATIONS
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }

    // BOOKMARKS
    match /users/{userId}/bookmarks/{postId} {
      allow read, write: if isOwner(userId);
    }

    // USER IMAGES (AI History)
    match /user_images/{imageId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // NEWSLETTER SUBSCRIBERS
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read: if isSignedIn(); // Simplified, ideally restricted to admins
    }

    // FOLLOWS
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }
  }
}
