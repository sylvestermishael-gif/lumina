{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Store user profile information and preferences.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "website": { "type": "string" },
        "followersCount": { "type": "integer" },
        "followingCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPremium": { "type": "boolean" }
      },
      "required": ["id", "displayName", "email"]
    },
    "Subscriber": {
      "title": "Newsletter Subscriber",
      "description": "Store email addresses of people who subscribed to the newsletter.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "subscribedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Post": {
      "title": "Blog Post",
      "description": "Represents a blog article published by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "summary": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "coverImage": { "type": "string" },
        "likesCount": { "type": "integer" },
        "viewsCount": { "type": "integer" },
        "commentsCount": { "type": "integer" },
        "isTrending": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a blog post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "text"]
    },
    "Community": {
      "title": "Community",
      "description": "A group for discussing specific topics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "memberCount": { "type": "integer" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app alerts for users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow"] },
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "postId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type"]
    },
    "UserImage": {
      "title": "AI Generated Image",
      "description": "History of images generated by the user using AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "url": { "type": "string" },
        "prompt": { "type": "string" },
        "style": { "type": "string" },
        "aspectRatio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "url", "prompt"]
    },
    "Follow": {
      "title": "Follow Relationship",
      "description": "Represents one user following another.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profile data."
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "User follow relationships."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Public blog articles."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments nested under posts for easier management."
    },
    "/communities/{communityId}": {
      "schema": "Community",
      "description": "Topic-based community groups."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific notifications."
    },
    "/users/{userId}/bookmarks/{postId}": {
      "schema": { "type": "object", "properties": { "addedAt": { "type": "string" } } },
      "description": "Saved posts by a user."
    },
    "/user_images/{imageId}": {
      "schema": "UserImage",
      "description": "User's AI image generation history."
    },
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Email newsletter subscribers."
    }
  }
}
